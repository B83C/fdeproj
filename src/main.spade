struct In {
    valid: bool,
    data: uint<8>,
}

struct Out {
    valid: bool,
    data: uint<8>,
}

struct Tpm {
    clk: clock,
    rst: bool,
    input: In,
    output_ready: In,
}

enum State {
    Idle,
    Absorb,
    Compute,
    Output
}

entity lsfr(clk: Clock) -> uint<16> {
    reg(clk) output = output .+ 1;
}


