module tpm_aes (
    input  logic        clk,
    input  logic        rst,

    input  logic        in_valid,
    output logic        in_ready,
    input  logic [7:0]  in_data,

    output logic        out_valid,
    input  logic        out_ready,
    output logic [7:0]  out_data,

    output logic        tick
);

    logic [127:0] key = 128'h00112233445566778899aabbccddeeff;

    typedef enum logic [1:0] {
        IDLE,
        ABSORB,
        COMPUTE,
        OUTPUT
    } state_t;

    state_t state;

    logic [127:0] msg;
    logic [3:0]   byte_cnt;

    logic [63:0] v0, v1, v2, v3;
    logic [127:0] result;

    logic [3:0] round;

    logic [127:0] out_buf;
    logic [4:0]   out_cnt;

    logic          tick_reg;

    function automatic [255:0] sip_round(
        input [63:0] a, b, c, d
    );
        logic [63:0] v0, v1, v2, v3;
        begin
            v0 = a + b;
            v1 = (b << 13) | (b >> 51);
            v1 = v1 ^ v0;
            v0 = (v0 << 32) | (v0 >> 32);

            v2 = c + d;
            v3 = (d << 16) | (d >> 48);
            v3 = v3 ^ v2;

            v0 = v0 + v3;
            v3 = (v3 << 21) | (v3 >> 43);
            v3 = v3 ^ v0;

            v2 = v2 + v1;
            v1 = (v1 << 17) | (v1 >> 47);
            v1 = v1 ^ v2;

            sip_round = {v0, v1, v2, v3};
        end
    endfunction

    always_ff @(posedge clk) begin
        if (rst) begin
            state    <= IDLE;
            byte_cnt <= 0;
            out_cnt  <= 0;
            out_valid <= 0;
            tick_reg  <= 1'b0;
        end else begin
            tick_reg <= ~tick_reg;
            case (state)

            IDLE: begin
                in_ready <= 1;
                if (in_valid) begin
                    msg <= {msg[119:0], in_data};
                    byte_cnt <= 1;
                    state <= ABSORB;
                end
            end

            ABSORB: begin
                if (in_valid && in_ready) begin
                    msg <= {msg[119:0], in_data};
                    byte_cnt <= byte_cnt + 1;

                    if (byte_cnt == 15) begin
                        state <= COMPUTE;
                        in_ready <= 0;

                        v0 <= key[63:0] ^ 64'h736f6d6570736575;
                        v1 <= key[127:64] ^ 64'h646f72616e646f6d;
                        v2 <= key[63:0] ^ 64'h6c7967656e657261;
                        v3 <= key[127:64] ^ 64'h7465646279746573;

                        round <= 0;
                    end
                end
            end

            COMPUTE: begin
                logic [255:0] tmp;

                tmp = sip_round(v0, v1, v2, v3);
                {v0, v1, v2, v3} <= tmp;

                round <= round + 1;

                if (round == 7) begin
                    result <= {v0 ^ v2, v1 ^ v3};
                    out_buf <= {v0 ^ v2, v1 ^ v3};
                    out_cnt <= 0;
                    state <= OUTPUT;
                end
            end

            OUTPUT: begin
                if (out_ready && !out_valid) begin
                    out_valid <= 1;
                    out_data  <= out_buf[127:120];
                    out_buf   <= {out_buf[119:0], 8'h00};
                    out_cnt   <= out_cnt + 1;
                end else if (out_valid && out_ready) begin
                    out_valid <= 0;
                    if (out_cnt == 16) begin
                        state <= IDLE;
                        in_ready <= 1;
                        out_cnt <= 0;
                    end
                end
            end

            endcase
        end
    end

    assign tick = tick_reg;

endmodule
