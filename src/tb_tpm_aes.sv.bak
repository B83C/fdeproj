`include "tb_common.sv"

module tb_tpm_aes;
    
    tb_common #(.TOP_MODULE("tpm_aes"), .CLOCK_HALF_PERIOD(5)) tb();
    
    wire clk = tb.clk;
    wire rst = ~tb.rst_n;
    
    logic       in_valid;
    logic       in_ready;
    logic [7:0] in_data;
    
    logic       out_valid;
    logic       out_ready;
    logic [7:0] out_data;
    
    tpm_aes uut (
        .clk       (clk),
        .rst       (rst),
        .in_valid  (in_valid),
        .in_ready  (in_ready),
        .in_data   (in_data),
        .out_valid (out_valid),
        .out_ready (out_ready),
        .out_data  (out_data)
    );
    
    initial begin
        repeat(500) @(posedge clk);
        tb.done = 1;
        $finish;
    end
    
    logic [7:0] test_msg [0:15];
    initial begin
        test_msg[0]  = 8'h48; // H
        test_msg[1]  = 8'h65; // e
        test_msg[2]  = 8'h6c; // l
        test_msg[3]  = 8'h6c; // o
        test_msg[4]  = 8'h20; // space
        test_msg[5]  = 8'h57; // W
        test_msg[6]  = 8'h6f; // o
        test_msg[7]  = 8'h72; // r
        test_msg[8]  = 8'h6c; // l
        test_msg[9]  = 8'h64; // d
        test_msg[10] = 8'h21; // !
        test_msg[11] = 8'h00;
        test_msg[12] = 8'h00;
        test_msg[13] = 8'h00;
        test_msg[14] = 8'h00;
        test_msg[15] = 8'h00;
    end
    
    logic [4:0] send_idx;
    logic [4:0] recv_idx;
    
    always @(posedge clk) begin
        if (rst) begin
            in_valid  <= 0;
            in_data  <= 0;
            send_idx <= 0;
            out_ready <= 1;
            recv_idx <= 0;
        end else begin
            /* verilator lint_off WIDTHEXPAND */
            if (in_ready && !in_valid && send_idx < 16) begin
                in_valid <= 1;
                in_data  <= test_msg[send_idx[3:0]];
                send_idx <= send_idx + 1;
            end else begin
                in_valid <= 0;
            end
            
            if (out_valid && out_ready && recv_idx < 16) begin
            /* verilator lint_on WIDTHEXPAND */
                $display("out[%0d] = 0x%02h", recv_idx, out_data);
                recv_idx <= recv_idx + 1;
            end
        end
    end

endmodule